# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blog
DB_USERNAME=root
DB_PASSWORD=your_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-must-be-at-least-256-bits-long
JWT_EXPIRATION=7200000

# AES Configuration
AES_SECRET_KEY=your-aes-key-256bits-must-be-32bytes!!

# Upload Configuration
UPLOAD_PATH=./uploads
UPLOAD_MAX_SIZE=10MB

# Logging Configuration
LOG_PATH=./logs
LOG_NAME=./logs/blog-server.log